@page "/products"
@inject GatewayApiClient ApiClient

<PageTitle>Products</PageTitle>

<h1 class="mb-4">Products</h1>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header">Add Product</div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    <div class="alert @(IsError ? "alert-danger" : "alert-success")">@StatusMessage</div>
                }

                <EditForm Model="ProductForm" OnValidSubmit="CreateProductAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="ProductForm.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Price</label>
                        <InputNumber class="form-control" @bind-Value="ProductForm.Price" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Stock</label>
                        <InputNumber class="form-control" @bind-Value="ProductForm.Stock" />
                    </div>

                    <button class="btn btn-primary" type="submit" disabled="@IsSubmitting">@(IsSubmitting ? "Saving..." : "Add Product")</button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>All Products</span>
                <button class="btn btn-outline-secondary btn-sm" @onclick="LoadProductsAsync">Refresh</button>
            </div>
            <div class="card-body p-0">
                @if (IsLoading)
                {
                    <div class="p-3">Loading products...</div>
                }
                else if (!string.IsNullOrWhiteSpace(LoadError))
                {
                    <div class="alert alert-danger m-3">@LoadError</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>Stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in ProductItems)
                                {
                                    <tr>
                                        <td>@product.Id</td>
                                        <td>@product.Name</td>
                                        <td>@product.Price.ToString("C")</td>
                                        <td>@product.Stock</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<ProductDto> ProductItems { get; set; } = new();
    private CreateProductDto ProductForm { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool IsSubmitting { get; set; }
    private string? LoadError { get; set; }
    private string? StatusMessage { get; set; }
    private bool IsError { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        IsLoading = true;
        LoadError = null;

        try
        {
            ProductItems = await ApiClient.GetProductsAsync();
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CreateProductAsync()
    {
        IsSubmitting = true;
        StatusMessage = null;

        try
        {
            await ApiClient.CreateProductAsync(ProductForm);
            ProductForm = new CreateProductDto();
            IsError = false;
            StatusMessage = "Product added successfully.";
            await LoadProductsAsync();
        }
        catch (Exception ex)
        {
            IsError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
