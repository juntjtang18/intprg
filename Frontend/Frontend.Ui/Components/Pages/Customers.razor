@page "/customers"
@inject GatewayApiClient ApiClient

<PageTitle>Customers</PageTitle>

<h1 class="mb-4">Customers</h1>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header">Add Customer</div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    <div class="alert @(IsError ? "alert-danger" : "alert-success")">@StatusMessage</div>
                }

                <EditForm Model="CustomerForm" OnValidSubmit="CreateCustomerAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="CustomerForm.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="CustomerForm.Email" />
                    </div>

                    <button class="btn btn-primary" type="submit" disabled="@IsSubmitting">@(IsSubmitting ? "Saving..." : "Add Customer")</button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>All Customers</span>
                <button class="btn btn-outline-secondary btn-sm" @onclick="LoadCustomersAsync">Refresh</button>
            </div>
            <div class="card-body p-0">
                @if (IsLoading)
                {
                    <div class="p-3">Loading customers...</div>
                }
                else if (!string.IsNullOrWhiteSpace(LoadError))
                {
                    <div class="alert alert-danger m-3">@LoadError</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var customer in CustomerItems)
                                {
                                    <tr>
                                        <td>@customer.Id</td>
                                        <td>@customer.Name</td>
                                        <td>@customer.Email</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<CustomerDto> CustomerItems { get; set; } = new();
    private CreateCustomerDto CustomerForm { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool IsSubmitting { get; set; }
    private string? LoadError { get; set; }
    private string? StatusMessage { get; set; }
    private bool IsError { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomersAsync();
    }

    private async Task LoadCustomersAsync()
    {
        IsLoading = true;
        LoadError = null;

        try
        {
            CustomerItems = await ApiClient.GetCustomersAsync();
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CreateCustomerAsync()
    {
        IsSubmitting = true;
        StatusMessage = null;

        try
        {
            await ApiClient.CreateCustomerAsync(CustomerForm);
            CustomerForm = new CreateCustomerDto();
            IsError = false;
            StatusMessage = "Customer added successfully.";
            await LoadCustomersAsync();
        }
        catch (Exception ex)
        {
            IsError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
