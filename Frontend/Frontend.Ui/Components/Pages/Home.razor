@page "/"

<PageTitle>Dashboard</PageTitle>

<h1 class="mb-4">Containerized E-Commerce Frontend</h1>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Products</h5>
                <p class="card-text">View all products and add new product records through the API Gateway.</p>
                <a class="btn btn-primary" href="/products">Open Products</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Customers</h5>
                <p class="card-text">View registered customers and add new customers using the frontend form.</p>
                <a class="btn btn-primary" href="/customers">Open Customers</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Orders</h5>
                <p class="card-text">Create orders and view complete order details with customer, product, and payment data.</p>
                <a class="btn btn-primary" href="/orders">Open Orders</a>
            </div>
        </div>
    </div>
</div>
